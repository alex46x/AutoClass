# Copy this file to .env.local for local development.
# Never commit real production secrets.

# Required in production. Use a long random value.
JWT_SECRET=

# Optional. Protects /api/setup. Required if you want to seed remotely.
SETUP_TOKEN=

# Optional. If not provided, the app creates local.db in the project folder.
SQLITE_DB_URL=

# Optional seed credentials. Set these privately in Vercel/local env if you use /api/setup.
SEED_ADMIN_PASSWORD=
SEED_TEACHER_PASSWORD=
SEED_HEAD_PASSWORD=
SEED_CR_PASSWORD=
SEED_STUDENT_PASSWORD=